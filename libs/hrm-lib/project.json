{
  "name": "hrm-lib",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/hrm-lib/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "type:lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/hrm-lib/ng-package.json",
        "tsConfig": "libs/hrm-lib/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/hrm-lib/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/hrm-lib/.storybook",
        "browserTarget": "hrm-lib:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/hrm-lib",
        "configDir": "libs/hrm-lib/.storybook",
        "browserTarget": "hrm-lib:build-storybook",
        "styles": [
          "apps/hrm-app/src/styles.scss"
        ],
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/hrm-lib/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "hrm-lib:build-storybook",
        "staticFilePath": "dist/storybook/hrm-lib",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "hrm-lib:build-storybook:ci"
        }
      }
    }
  }
}
